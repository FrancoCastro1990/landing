---
import '@shared/styles/global.css';
import { portfolioData } from '@app';
import { Hero } from '@features/hero';
import { Header } from '@features/navigation';
import { About } from '@features/about';
import { Experience } from '@features/experience';
import { ProjectsGrid } from '@features/projects';
import { Contact } from '@features/contact';
import { Footer } from '@features/layout';
import { ThemeCustomizer } from '@features/theme-customizer';
import { NodeNetwork } from '@features/background';

const { personal, hero, about, experience, projects, contact, navigation, seo } = portfolioData;

const footerLinks = [
  ...personal.socialLinks,
  { label: 'Email', url: `mailto:${personal.email}` },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={seo.description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{seo.title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={seo.ogTitle} />
    <meta property="og:description" content={seo.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={personal.siteUrl} />
    <meta property="og:site_name" content={personal.name} />
    <meta property="og:image" content={seo.ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.ogTitle} />
    <meta name="twitter:description" content={seo.ogDescription} />
    <meta name="twitter:image" content={seo.ogImage} />

    <!-- Fonts — loaded via link, not CSS @import, to avoid render blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@1,400;1,700&family=Manrope:wght@400;700;800&display=swap" />

    <!-- Theme color -->
    <meta name="theme-color" content="#000000" />

    <!-- Restore saved theme before render -->
    <script is:inline>
      (function() {
        try {
          var saved = localStorage.getItem('portfolio-theme');
          if (saved) {
            var vars = JSON.parse(saved);
            var root = document.documentElement;
            Object.keys(vars).forEach(function(key) {
              root.style.setProperty(key, vars[key]);
            });
          }
        } catch (e) {}
      })();
    </script>

    <!-- Additional SEO -->
    <meta name="author" content={personal.name} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={personal.siteUrl} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: personal.name,
      url: personal.siteUrl,
      jobTitle: personal.title,
      email: personal.email,
      sameAs: personal.socialLinks.map((link) => link.url),
    })} />
  </head>
  <body class="bg-surface-lowest text-on-surface font-body">
    <NodeNetwork client:idle />

    <!-- Header -->
    <Header client:load brandName={personal.brandName} navItems={navigation.items} />

    <!-- Main Content -->
    <main>
      <Hero client:visible headline={hero.headline} label={hero.label} bio={hero.bio} />
      <About client:visible sectionTitle={about.sectionTitle} bio={about.bio} stats={about.stats} skills={about.skills} />
      <Experience client:visible items={experience.items} />
      <ProjectsGrid client:visible items={projects.items} />
      <Contact client:visible headline={contact.headline} email={personal.email} socialLinks={personal.socialLinks} />
    </main>

    <!-- Footer -->
    <Footer client:visible name={personal.name} links={footerLinks} />

    <!-- Theme Customizer -->
    <ThemeCustomizer client:idle />
  </body>
</html>

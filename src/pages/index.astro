---
import '@shared/styles/global.css';
import { Hero } from '@features/hero';
import { Header } from '@features/navigation';
import { About } from '@features/about';
import { Experience } from '@features/experience';
import { ProjectsGrid } from '@features/projects';
import { Contact } from '@features/contact';
import { Footer } from '@features/layout';
import { ThemeCustomizer } from '@features/theme-customizer';
import { NodeNetwork } from '@features/background';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Franco Castro — Desarrollador Full Stack con 6+ anos de experiencia en React, TypeScript y Arquitectura Limpia." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Franco Castro — Desarrollador Full Stack</title>

    <!-- Open Graph -->
    <meta property="og:title" content="Franco Castro — Desarrollador Full Stack" />
    <meta property="og:description" content="Desarrollador Full Stack con 6+ anos de experiencia. Especializado en React, TypeScript, Arquitectura Limpia y mentorias de equipo." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fcastro.dev" />
    <meta property="og:site_name" content="Franco Castro" />
    <meta property="og:image" content="https://fcastro.dev/og-image.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Franco Castro — Desarrollador Full Stack" />
    <meta name="twitter:description" content="Desarrollador Full Stack con 6+ anos de experiencia en React, TypeScript y Arquitectura Limpia" />
    <meta name="twitter:image" content="https://fcastro.dev/og-image.png" />

    <!-- Fonts — loaded via link, not CSS @import, to avoid render blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Newsreader:ital,wght@1,400;1,700&family=Manrope:wght@400;700;800&display=swap" />

    <!-- Theme color -->
    <meta name="theme-color" content="#000000" />

    <!-- Restore saved theme before render -->
    <script is:inline>
      (function() {
        try {
          var saved = localStorage.getItem('portfolio-theme');
          if (saved) {
            var vars = JSON.parse(saved);
            var root = document.documentElement;
            Object.keys(vars).forEach(function(key) {
              root.style.setProperty(key, vars[key]);
            });
          }
        } catch (e) {}
      })();
    </script>

    <!-- Additional SEO -->
    <meta name="author" content="Franco Castro" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://fcastro.dev" />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Franco Castro",
        "url": "https://fcastro.dev",
        "jobTitle": "Desarrollador Full Stack",
        "email": "franco.castro.villanueva.90@gmail.com",
        "sameAs": [
          "https://github.com/FrancoCastro1990",
          "https://www.linkedin.com/in/franco-castro-villanueva-035905174/"
        ]
      }
    </script>
  </head>
  <body class="bg-surface-lowest text-on-surface font-body">
    <NodeNetwork client:idle />

    <!-- Header -->
    <Header client:load />

    <!-- Main Content -->
    <main>
      <Hero client:visible />
      <About client:visible />
      <Experience client:visible />
      <ProjectsGrid client:visible />
      <Contact client:visible />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Theme Customizer -->
    <ThemeCustomizer client:idle />
  </body>
</html>
